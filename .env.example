# Ubuntu Server .env file for docker-compose
# Copy this to .env and fill in your values

# Frontend URLs - use Tailscale IP of Ubuntu server
NEXT_PUBLIC_API_URL=http://100.x.x.x:8000
NEXT_PUBLIC_WS_URL=ws://100.x.x.x:8000

# MT5 Bridge - Tailscale IP of your Windows PC running mt5_bridge.py
MT5_BRIDGE_URL=http://100.x.x.x:8001

# AI Provider (9router via Tailscale)
ANTHROPIC_BASE_URL=http://10.254.200.211:20128/v1
ANTHROPIC_AUTH_TOKEN=sk_9router
ANTHROPIC_MODEL=claude

# CORS - allow frontend origin
ALLOWED_ORIGINS=http://100.x.x.x:3000,http://localhost:3000

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Symbols
SYMBOLS=XAUUSD.m,EURUSD.m,GBPUSD.m,BTCUSD.m
